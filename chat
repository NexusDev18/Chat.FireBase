local function SendMessage()
    local text = ChatBox.Text
    if text == "" then return end

    local messageId = tostring(os.time()) .. "_" .. tostring(LocalPlayer.UserId)
    local isDev = (LocalPlayer.Name == DeveloperName)

    local messageData = {
        sender = LocalPlayer.DisplayName,
        realName = LocalPlayer.Name,
        content = text,
        userId = LocalPlayer.UserId,
        timestamp = os.time(),
        id = messageId,
        isDeveloper = isDev
    }

    local encodedData = HttpService:JSONEncode(messageData)

    pcall(function()
        MakeRequest("POST", DB_URL, encodedData)
    end)

    SendToRobloxChat(text)

    CreateMessageFrame(LocalPlayer.DisplayName, text, LocalPlayer.UserId, isDev)

    SentMessagesCache[messageId] = true

    if CurrentEditMessage and CurrentEditMessage.Parent then
        CurrentEditMessage:Destroy()
        CurrentEditMessage = nil
    end

    ChatBox.Text = ""
end

SendButton.MouseButton1Click:Connect(SendMessage)

ChatBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        SendMessage()
    end
end)

local NoticeSound = Instance.new('Sound')
NoticeSound.SoundId = 'rbxassetid://2865226708'
NoticeSound.Name = 'NoticeReciveSound'
NoticeSound.Parent = ScreenGui

task.spawn(function()
    while true do
        task.wait(0.3)

        local response = MakeRequest("GET", DB_URL)

        if response and response.Body and response.Body ~= "null" then
            local success, data = pcall(function()
                return HttpService:JSONDecode(response.Body)
            end)

            if success and data then
                for id, messageData in pairs(data) do
                    if messageData.content and messageData.sender and not SentMessagesCache[id] then
                        if messageData.timestamp and messageData.timestamp > lastTimestamp then
                            if messageData.realName ~= LocalPlayer.Name then
                                CreateMessageFrame(messageData.sender, messageData.content, messageData.userId or 0, messageData.isDeveloper or false)
                                NoticeSound:Play()
                            end
                            lastTimestamp = messageData.timestamp
                            SentMessagesCache[id] = true
                        end
                    end
                end
            end
        end
    end
end)

return ScreenGui
