local function GetAvatarImage(userId)
    if not userId or userId == 0 then
        return "rbxasset://textures/ui/GuiImagePlaceholder.png"
    end

    local success, imageUrl = pcall(function()
        return Players:GetUserThumbnailAsync(userId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48)
    end)

    if success and imageUrl and imageUrl ~= "" and imageUrl ~= "rbxassetid://0" then
        return imageUrl
    end

    return "rbxthumb://type=AvatarHeadShot&id=" .. tostring(userId) .. "&w=48&h=48"
end

local ChatService = game:GetService('Chat')

local function SendToRobloxChat(message)
    pcall(function()
        ChatService:Chat(LocalPlayer.Character.Head, message)
    end)
    pcall(function()
        local chatRemote = ReplicatedStorage:FindFirstChild("ChatRemote")
        if chatRemote and chatRemote:IsA("RemoteEvent") then
            chatRemote:FireServer(message)
        end
    end)
    pcall(function()
        local TextChatService = game:GetService("TextChatService")
        if TextChatService and TextChatService.TextChannels then
            local generalChannel = TextChatService.TextChannels:FindFirstChild("General")
            if generalChannel then
                generalChannel:SendAsync(message)
            end
        end
    end)
end

